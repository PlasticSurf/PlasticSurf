---
interface FAQItem {
  q: string;
  a: string;
}

interface Props {
  questions?: FAQItem[];
  title?: string;
}

const { questions = [], title = 'Häufig gestellte Fragen' } = Astro.props;
---

<div class="my-8">
  <h3 class="font-display text-2xl text-gray-900 mb-6">{title}</h3>
  {questions.length > 0 ? (
    <div class="space-y-4">
      {questions.map((item) => (
        <details class="group bg-gray-100 rounded-lg border border-gray-200">
          <summary class="flex items-center justify-between cursor-pointer p-4 list-none">
            <span class="font-heading text-gray-900 font-medium pr-4">{item.q}</span>
            <svg
              class="w-5 h-5 text-primary flex-shrink-0 transition-transform duration-200 group-open:rotate-180"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-4 pb-4">
            <p class="font-body text-gray-700 text-sm leading-relaxed">{item.a}</p>
          </div>
        </details>
      ))}
    </div>
  ) : (
    <div class="space-y-4">
      <slot />
    </div>
  )}
</div>
