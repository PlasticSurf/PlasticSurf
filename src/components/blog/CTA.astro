---
interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
  href?: string;
  variant?: 'primary' | 'secondary';
}

const { title = 'Bereit für den nächsten Schritt?', description, buttonText = 'Jetzt kontaktieren', href = '/kontakt', variant = 'primary' } = Astro.props;
---

<div class="my-8 p-8 bg-primary rounded-xl text-white text-center">
  {title && (
    <h3 class="font-heading text-2xl font-bold mb-3">{title}</h3>
  )}
  {description && (
    <p class="font-body text-white/90 mb-6 max-w-lg mx-auto">{description}</p>
  )}
  <a
    href={href}
    class={
      variant === 'primary'
        ? 'inline-block bg-white text-primary px-8 py-3 rounded-md font-heading font-semibold transition-all duration-200 hover:bg-gray-100 hover:shadow-lg'
        : 'inline-block border-2 border-white text-white px-8 py-3 rounded-md font-heading font-semibold transition-all duration-200 hover:bg-white hover:text-primary'
    }
  >
    {buttonText}
  </a>
</div>
