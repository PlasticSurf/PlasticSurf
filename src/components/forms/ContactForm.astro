---
interface Props {
  formName?: string;
}

const { formName = 'kontakt-kontaktseite' } = Astro.props;
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<div class="w-full max-w-lg mx-auto">
  <form id="contact-form" method="POST" action="/api/kontakt" class="space-y-6">
    <input type="hidden" name="seite" value={formName} />

    <!-- Name -->
    <div>
      <label for="name" class="block font-heading text-text mb-2">Name *</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        class="w-full px-4 py-3 bg-background/40 border border-white/10 rounded-md text-text font-body focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-transparent transition-all duration-200"
        placeholder="Ihr Name"
      />
    </div>

    <!-- Email -->
    <div>
      <label for="email" class="block font-heading text-text mb-2">E-Mail *</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        class="w-full px-4 py-3 bg-background/40 border border-white/10 rounded-md text-text font-body focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-transparent transition-all duration-200"
        placeholder="ihre@email.de"
      />
    </div>

    <!-- Firma -->
    <div>
      <label for="company" class="block font-heading text-text mb-2">Firma</label>
      <input
        type="text"
        id="company"
        name="company"
        class="w-full px-4 py-3 bg-background/40 border border-white/10 rounded-md text-text font-body focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-transparent transition-all duration-200"
        placeholder="Ihre Firma"
      />
    </div>

    <!-- Telefon -->
    <div>
      <label for="phone" class="block font-heading text-text mb-2">Telefon</label>
      <input
        type="tel"
        id="phone"
        name="phone"
        class="w-full px-4 py-3 bg-background/40 border border-white/10 rounded-md text-text font-body focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-transparent transition-all duration-200"
        placeholder="+49 ..."
      />
    </div>

    <!-- Nachricht -->
    <div>
      <label for="message" class="block font-heading text-text mb-2">Nachricht *</label>
      <textarea
        id="message"
        name="nachricht"
        required
        rows={5}
        class="w-full px-4 py-3 bg-background/40 border border-white/10 rounded-md text-text font-body focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-transparent transition-all duration-200 resize-none"
        placeholder="Wie kann ich helfen?"
      ></textarea>
    </div>

    <!-- Datenschutz -->
    <div>
      <label class="flex items-start gap-3 cursor-pointer">
        <input
          type="checkbox"
          name="privacy"
          required
          class="mt-1 w-4 h-4 rounded border-white/10 bg-background/40 text-primary focus:ring-primary/50"
        />
        <span class="font-body text-text/60 text-sm">
          Ich habe die{' '}
          <a href="/datenschutz" class="text-primary underline hover:no-underline">Datenschutzerklärung</a>{' '}
          gelesen und stimme der Verarbeitung meiner Daten zu. *
        </span>
      </label>
    </div>

    <!-- Turnstile -->
    <div class="cf-turnstile" data-sitekey={siteKey} data-theme="dark"></div>

    <!-- Submit -->
    <div>
      <button type="submit" id="contact-submit" class="btn-primary w-full md:w-auto">
        Nachricht senden
      </button>
    </div>

    <!-- Feedback -->
    <div id="contact-feedback" class="hidden font-body text-sm rounded-md px-4 py-3"></div>
  </form>
</div>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn  = document.getElementById('contact-submit') as HTMLButtonElement;
  const fb   = document.getElementById('contact-feedback') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Wird gesendet…';
    fb.className = 'hidden';

    try {
      const res = await fetch('/api/kontakt', {
        method: 'POST',
        body: new FormData(form),
      });
      const json = await res.json();

      if (res.ok) {
        form.reset();
        fb.textContent = 'Vielen Dank! Ihre Nachricht wurde gesendet.';
        fb.className = 'font-body text-sm rounded-md px-4 py-3 bg-green-500/10 text-green-400 border border-green-500/20';
        // Turnstile zurücksetzen
        if (typeof window !== 'undefined' && (window as any).turnstile) {
          (window as any).turnstile.reset();
        }
      } else {
        fb.textContent = json.error || 'Ein Fehler ist aufgetreten.';
        fb.className = 'font-body text-sm rounded-md px-4 py-3 bg-red-500/10 text-red-400 border border-red-500/20';
      }
    } catch {
      fb.textContent = 'Verbindungsfehler. Bitte versuche es später nochmal.';
      fb.className = 'font-body text-sm rounded-md px-4 py-3 bg-red-500/10 text-red-400 border border-red-500/20';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Nachricht senden';
    }
  });
</script>
