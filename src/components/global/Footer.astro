---
const currentYear = new Date().getFullYear();

const footerLinks = {
  loesungen: [
    { name: 'Der Performance Audit', href: '/loesungen/der-performance-audit' },
    { name: 'Der Wachstums-Motor', href: '/loesungen/der-wachstums-motor' },
    { name: 'Das Digitale Vermächtnis', href: '/loesungen/das-digitale-vermaechtnis' },
    { name: 'Das Brand Experience System', href: '/loesungen/das-brand-experience-system' },
  ],
  unternehmen: [
    { name: 'Erlebnisse', href: '/erlebnisse' },
    { name: 'Gedanken', href: '/gedanken' },
    { name: 'Die DNA', href: '/die-dna' },
    { name: 'Kontakt', href: '/kontakt' },
  ],
};
---

<footer class="bg-background border-t border-white/10">
  <div class="container-custom section-padding">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- STOP WAR -->
      <div class="flex items-center justify-center lg:justify-start">
        <img src="/images/STOP-WAR.png" alt="PlasticSurf - STOP WAR" class="max-h-40 w-auto" />
      </div>

      <!-- Logo & Description -->
      <div>
        <a href="/" class="inline-block mb-4">
          <img src="/images/PlasticSurf-Logo-KI-Werbeagentur-Freiburg.svg" alt="PlasticSurf – KI Werbeagentur Freiburg" class="h-10 w-auto" />
        </a>
        <p class="font-body text-text/60 text-sm leading-relaxed">
          Digitale Lösungen für Ihr Unternehmen. Wir transformieren Ihre Vision in digitale Realität.
        </p>
      </div>

      <!-- Lösungen -->
      <div>
        <h3 class="font-heading text-lg text-text mb-4">Lösungen</h3>
        <ul class="space-y-2">
          {footerLinks.loesungen.map((link) => (
            <li>
              <a href={link.href} class="font-body text-text/60 hover:text-primary transition-colors duration-200 text-sm">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Unternehmen -->
      <div>
        <h3 class="font-heading text-lg text-text mb-4">Unternehmen</h3>
        <ul class="space-y-2">
          {footerLinks.unternehmen.map((link) => (
            <li>
              <a href={link.href} class="font-body text-text/60 hover:text-primary transition-colors duration-200 text-sm">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-white/10">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="font-body text-text/40 text-sm flex flex-wrap items-center gap-x-4 gap-y-1">
          <span>© 1997 - {currentYear} PlasticSurf. Alle Rechte vorbehalten.</span>
          <span class="flex items-center gap-x-3">
            <a href="/impressum" class="hover:text-primary transition-colors duration-200">Impressum</a>
            <span class="text-text/20">|</span>
            <a href="/datenschutz" class="hover:text-primary transition-colors duration-200">Datenschutz</a>
          </span>
        </p>
        <div class="flex items-center space-x-6">
          <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" class="text-text/40 hover:text-primary transition-colors duration-200" aria-label="LinkedIn" title="PlasticSurf auf LinkedIn">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>