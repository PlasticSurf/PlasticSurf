---
interface Props {
  formName: string;
  headline: string;
  subline: string;
  text: string;
  placeholder?: string;
}

const {
  formName,
  headline,
  subline,
  text,
  placeholder = 'Wo spüren Sie aktuell den größten Widerstand?',
} = Astro.props;

const paragraphs = text.split('\n\n').filter(Boolean);
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<section id="kontakt" class="section-padding-lg bg-background border-t border-white/5">
  <div class="container-custom">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 items-start">

      <!-- Text links -->
      <div class="md:col-span-2 reveal">
        <h2 class="font-primary text-[3.125rem] font-black leading-tight mb-1">{headline}</h2>
        <p class="font-secondary text-2xl text-[#927350] mb-8">{subline}</p>
        <div class="font-body text-base text-text/80 leading-relaxed space-y-4">
          {paragraphs.map((p) => <p>{p}</p>)}
        </div>
      </div>

      <!-- Formular rechts -->
      <div class="reveal reveal-delay-200">
        <form
          id={`ks-form-${formName}`}
          method="POST"
          action="/api/kontakt"
          class="space-y-4"
        >
          <input type="hidden" name="seite" value={formName} />

          <div>
            <label class="block text-sm text-text/50 mb-1">Name</label>
            <input
              type="text"
              name="name"
              required
              class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-text placeholder-text/30 focus:outline-none focus:border-primary transition-colors"
              placeholder="Ihr Name"
            />
          </div>
          <div>
            <label class="block text-sm text-text/50 mb-1">E-Mail</label>
            <input
              type="email"
              name="email"
              required
              class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-text placeholder-text/30 focus:outline-none focus:border-primary transition-colors"
              placeholder="ihre@email.de"
            />
          </div>
          <div>
            <label class="block text-sm text-text/50 mb-1">Nachricht</label>
            <textarea
              name="nachricht"
              rows="4"
              required
              class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-sm text-text placeholder-text/30 focus:outline-none focus:border-primary transition-colors resize-none"
              placeholder={placeholder}
            ></textarea>
          </div>

          <!-- Turnstile -->
          <div class="cf-turnstile" data-sitekey={siteKey} data-theme="dark" data-size="compact"></div>

          <button type="submit" class="btn-primary w-full">Senden</button>

          <!-- Feedback -->
          <div class="ks-feedback hidden font-body text-sm rounded-md px-4 py-3"></div>
        </form>
      </div>

    </div>
  </div>
</section>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  document.querySelectorAll<HTMLFormElement>('form[id^="ks-form-"]').forEach((form) => {
    const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
    const fb  = form.querySelector<HTMLElement>('.ks-feedback');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (btn) { btn.disabled = true; btn.textContent = 'Wird gesendet…'; }
      if (fb)  { fb.className = 'ks-feedback hidden'; }

      try {
        const res  = await fetch('/api/kontakt', { method: 'POST', body: new FormData(form) });
        const json = await res.json();

        if (res.ok) {
          form.reset();
          if (fb) {
            fb.textContent = 'Vielen Dank! Ihre Nachricht wurde gesendet.';
            fb.className = 'ks-feedback font-body text-sm rounded-md px-4 py-3 bg-green-500/10 text-green-400 border border-green-500/20';
          }
          if (typeof window !== 'undefined' && (window as any).turnstile) (window as any).turnstile.reset();
        } else {
          if (fb) {
            fb.textContent = json.error || 'Ein Fehler ist aufgetreten.';
            fb.className = 'ks-feedback font-body text-sm rounded-md px-4 py-3 bg-red-500/10 text-red-400 border border-red-500/20';
          }
        }
      } catch {
        if (fb) {
          fb.textContent = 'Verbindungsfehler. Bitte versuche es später nochmal.';
          fb.className = 'ks-feedback font-body text-sm rounded-md px-4 py-3 bg-red-500/10 text-red-400 border border-red-500/20';
        }
      } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Senden'; }
      }
    });
  });
</script>
