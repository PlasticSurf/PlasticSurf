---
const navLeft = [
  { name: 'Lösungen', href: '/loesungen' },
  { name: 'Erlebnisse', href: '/erlebnisse' },
];
const navRight = [
  { name: 'Gedanken', href: '/gedanken' },
  { name: 'Die DNA', href: '/die-dna' },
  { name: 'Kontakt', href: '/kontakt' },
];

const loesungenSub = [
  { name: 'Das Brand Experience System', href: '/loesungen/das-brand-experience-system' },
  { name: 'Das Digitale Vermächtnis', href: '/loesungen/das-digitale-vermaechtnis' },
  { name: 'Der Performance Audit', href: '/loesungen/der-performance-audit' },
  { name: 'Der Wachstums-Motor', href: '/loesungen/der-wachstums-motor' },
];

const currentPath = Astro.url.pathname;
const isActive = (href: string) => currentPath === href || currentPath.startsWith(href + '/');
---

<header class="fixed top-0 left-0 right-0 z-50 bg-gradient-to-b from-background/95 via-background/65 to-transparent">
  <div class="container-custom">
    <div class="grid grid-cols-3 items-center h-20">

      <!-- Left: Schriftzug + Nav Links -->
      <div class="flex items-center gap-8">
        <a href="/" class={`font-primary font-black text-sm tracking-wide transition-colors duration-200 ${currentPath === '/' ? 'text-primary' : 'text-text hover:text-primary'}`}>
          PlasticSurf
        </a>
        <nav class="hidden md:flex items-center gap-6">
          {navLeft.map((item) => (
            <a
              href={item.href}
              class={`font-body text-sm transition-colors duration-200 ${isActive(item.href) ? 'text-primary' : 'text-text hover:text-primary'}`}
            >
              {item.name}
            </a>
          ))}
        </nav>
      </div>

      <!-- Center: Logo -->
      <div class="flex justify-center">
        <a href="/" class="flex items-center">
          <img src="/images/PlasticSurf-Logo-KI-Werbeagentur-Freiburg.svg" alt="PlasticSurf – KI Werbeagentur Freiburg" class="h-10 w-auto" />
        </a>
      </div>

      <!-- Right: Nav Links + Mobile Burger -->
      <div class="flex items-center justify-end gap-6">
        <nav class="hidden md:flex items-center gap-6">
          {navRight.map((item) => (
            <a
              href={item.href}
              class={`font-body text-sm transition-colors duration-200 ${isActive(item.href) ? 'text-primary' : 'text-text hover:text-primary'}`}
            >
              {item.name}
            </a>
          ))}
        </nav>

        <!-- Mobile Burger Button -->
        <button
          id="burger-button"
          class="md:hidden flex flex-col justify-center items-center w-10 h-10 bg-transparent border-none cursor-pointer focus:outline-none"
          aria-label="Menü öffnen"
        >
          <span class="burger-line block w-6 h-0.5 bg-text transition-all duration-300"></span>
          <span class="burger-line block w-6 h-0.5 bg-text my-1 transition-all duration-300"></span>
          <span class="burger-line block w-6 h-0.5 bg-text transition-all duration-300"></span>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile Navigation Sidebar -->
  <div
    id="mobile-nav"
    class="fixed top-0 right-0 h-full w-[70vw] bg-background transform translate-x-full transition-transform duration-300 ease-in-out z-50 md:hidden"
  >
    <div class="flex flex-col h-full">
      <!-- Close Button -->
      <div class="flex justify-end p-4">
        <button
          id="close-button"
          class="w-10 h-10 flex items-center justify-center bg-transparent border-none cursor-pointer focus:outline-none"
          aria-label="Menü schließen"
        >
          <svg class="w-6 h-6 text-text" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Navigation Links -->
      <nav class="flex flex-col px-8 space-y-6">
        <!-- Startseite -->
        <a
          href="/"
          class={`font-body text-xl transition-colors duration-200 ${currentPath === '/' ? 'text-primary' : 'text-text hover:text-primary'}`}
        >
          Startseite
        </a>
        <!-- Lösungen mit Unterseiten -->
        <div>
          <a
            href="/loesungen"
            class={`font-body text-xl transition-colors duration-200 ${isActive('/loesungen') ? 'text-primary' : 'text-text hover:text-primary'}`}
          >
            Lösungen
          </a>
          <div class="flex flex-col mt-3 ml-4 space-y-3 border-l border-white/10 pl-4">
            {loesungenSub.map((sub) => (
              <a
                href={sub.href}
                class={`font-body text-sm transition-colors duration-200 ${isActive(sub.href) ? 'text-primary' : 'text-text/70 hover:text-primary'}`}
              >
                {sub.name}
              </a>
            ))}
          </div>
        </div>
        <!-- Restliche Links -->
        {[...navLeft.filter(i => i.href !== '/loesungen'), ...navRight].map((item) => (
          <a
            href={item.href}
            class={`font-body text-xl transition-colors duration-200 ${isActive(item.href) ? 'text-primary' : 'text-text hover:text-primary'}`}
          >
            {item.name}
          </a>
        ))}
      </nav>

      <!-- Footer in Sidebar -->
      <div class="mt-auto p-8 space-y-2">
        <p class="font-body text-sm text-text/60">© 1997 – 2026 PlasticSurf</p>
        <div class="flex gap-4">
          <a href="/impressum" class="font-body text-sm text-text/60 hover:text-primary transition-colors duration-200">Impressum</a>
          <a href="/datenschutz" class="font-body text-sm text-text/60 hover:text-primary transition-colors duration-200">Datenschutz</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Overlay -->
  <div
    id="nav-overlay"
    class="fixed inset-0 bg-black/50 opacity-0 pointer-events-none transition-opacity duration-300 z-40 md:hidden"
  ></div>
</header>

<script>
  const burgerButton = document.getElementById('burger-button');
  const mobileNav = document.getElementById('mobile-nav');
  const closeButton = document.getElementById('close-button');
  const navOverlay = document.getElementById('nav-overlay');
  const burgerLines = document.querySelectorAll('.burger-line');

  function openNav() {
    mobileNav?.classList.remove('translate-x-full');
    navOverlay?.classList.remove('opacity-0', 'pointer-events-none');
    burgerLines[0]?.classList.add('rotate-45', 'translate-y-2');
    burgerLines[1]?.classList.add('opacity-0');
    burgerLines[2]?.classList.add('-rotate-45', '-translate-y-2');
  }

  function closeNav() {
    mobileNav?.classList.add('translate-x-full');
    navOverlay?.classList.add('opacity-0', 'pointer-events-none');
    burgerLines[0]?.classList.remove('rotate-45', 'translate-y-2');
    burgerLines[1]?.classList.remove('opacity-0');
    burgerLines[2]?.classList.remove('-rotate-45', '-translate-y-2');
  }

  burgerButton?.addEventListener('click', openNav);
  closeButton?.addEventListener('click', closeNav);
  navOverlay?.addEventListener('click', closeNav);

  // Close on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !navOverlay?.classList.contains('opacity-0')) {
      closeNav();
    }
  });
</script>

<style>
  .burger-line:first-child.rotate-45 {
    transform: rotate(45deg) translate(0, 4px);
  }
  .burger-line:last-child.-rotate-45 {
    transform: rotate(-45deg) translate(0, -4px);
  }
</style>