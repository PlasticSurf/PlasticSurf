---
---

<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-50 bg-background border-t border-white/10 p-4 md:p-6 transform translate-y-full transition-transform duration-300"
  role="alert"
  aria-live="polite"
>
  <div class="container-custom">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <!-- Text Content -->
      <div class="flex-1 text-center md:text-left">
        <p class="font-body text-text text-xs leading-relaxed">
          Wir verwenden Cookies und Google Analytics, um Ihnen die bestmögliche Erfahrung zu bieten.
          Weitere Informationen finden Sie in unserer{' '}
          <a href="/datenschutz" class="text-primary underline hover:no-underline">Datenschutzerklärung</a>.
        </p>
      </div>

      <!-- Buttons -->
      <div class="flex items-center gap-3 flex-shrink-0">
        <button
          id="cookie-decline"
          class="px-4 py-2 border border-text/30 text-text rounded-md font-body text-sm hover:bg-white/5 transition-colors duration-200"
        >
          Ablehnen
        </button>
        <button
          id="cookie-accept"
          class="btn-primary px-6 py-2"
        >
          Akzeptieren
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Widerruf-Link (wird nach Consent-Entscheidung sichtbar) -->
<div id="cookie-revoke-wrap" class="hidden fixed bottom-4 right-4 z-40">
  <button
    id="cookie-revoke"
    class="font-body text-xs text-text/30 hover:text-text/60 underline transition-colors duration-200"
  >
    Cookie-Einstellungen
  </button>
</div>

<script>
  const banner      = document.getElementById('cookie-banner');
  const btnAccept   = document.getElementById('cookie-accept');
  const btnDecline  = document.getElementById('cookie-decline');
  const revokeWrap  = document.getElementById('cookie-revoke-wrap');
  const btnRevoke   = document.getElementById('cookie-revoke');

  const STORAGE_KEY = 'cookie-consent';

  function hideBanner() {
    banner?.classList.add('translate-y-full');
  }

  function showBanner() {
    banner?.classList.remove('translate-y-full');
    revokeWrap?.classList.add('hidden');
  }

  function showRevoke() {
    revokeWrap?.classList.remove('hidden');
  }

  // Beim Laden prüfen
  const choice = localStorage.getItem(STORAGE_KEY);
  if (!choice) {
    setTimeout(showBanner, 1000);
  } else {
    showRevoke();
  }

  // Akzeptieren
  btnAccept?.addEventListener('click', () => {
    localStorage.setItem(STORAGE_KEY, 'accepted');
    hideBanner();
    showRevoke();
    // Custom Event → GoogleAnalytics.astro lädt GA sofort im selben Tab
    window.dispatchEvent(new CustomEvent('cookie-consent-accepted'));
  });

  // Ablehnen
  btnDecline?.addEventListener('click', () => {
    localStorage.setItem(STORAGE_KEY, 'declined');
    hideBanner();
    showRevoke();
  });

  // Widerruf
  btnRevoke?.addEventListener('click', () => {
    localStorage.removeItem(STORAGE_KEY);
    showBanner();
  });
</script>
