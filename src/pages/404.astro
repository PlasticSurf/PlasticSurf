---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('de-DE', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title="404 – Seite nicht gefunden | PlasticSurf"
  description="Diese Seite existiert nicht oder wurde verschoben."
>
  <section class="min-h-screen bg-background flex items-center section-padding">
    <div class="container-custom text-center">

      <p class="font-primary font-black text-primary leading-none mb-4 text-[8rem] md:text-[14rem]">
        404
      </p>

      <h1 class="reveal font-primary font-black text-4xl md:text-5xl text-text leading-[1.1] mb-4">
        Hier war mal was.<br />
        <span class="text-primary">Jetzt nicht mehr.</span>
      </h1>

      <p class="reveal reveal-delay-100 font-secondary italic text-[#927350] text-xl md:text-2xl mb-10">
        Diese Seite existiert nicht oder wurde verschoben.
      </p>

      <div class="reveal reveal-delay-200 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="btn-primary">Zur Startseite</a>
        <a href="/erlebnisse" class="btn-secondary">Unsere Erlebnisse</a>
      </div>

      <div class="reveal reveal-delay-300 mt-20">
        <p class="font-primary font-black text-xs uppercase tracking-widest text-primary mb-8">
          Vielleicht findest du das hier interessant
        </p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-left">
          {latestPosts.map((post) => (
            <article class="group">
              <a href={`/gedanken/${post.slug}`} class="block">
                <div class="aspect-video rounded-lg overflow-hidden bg-white/5 border border-white/10 mb-4">
                  <img
                    src={post.data.featuredImage}
                    alt={post.data.featuredImageAlt || post.data.title}
                    loading="lazy"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                </div>
                <span class="text-xs font-medium text-primary">{post.data.category}</span>
                <h2 class="font-primary font-black text-lg text-text mt-1 mb-2 group-hover:text-primary transition-colors leading-[1.2]">
                  {post.data.title}
                </h2>
                <p class="font-body text-text/60 text-sm line-clamp-2">
                  {post.data.excerpt}
                </p>
                <div class="mt-3 text-xs text-text/40">{formatDate(post.data.date)}</div>
              </a>
            </article>
          ))}
        </div>
      </div>

    </div>
  </section>
</BaseLayout>
