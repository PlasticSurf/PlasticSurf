---
import BaseLayout from '../layouts/BaseLayout.astro';
import { generateBreadcrumbSchema } from '../lib/seo';
import Hero from '../components/global/Hero.astro';
import HeroZone from '../components/global/HeroZone.astro';

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: 'https://www.plasticsurf.de/' },
  { name: 'Erlebnisse', url: 'https://www.plasticsurf.de/erlebnisse' },
]);

const pageTitle = 'Referenzen – Kreativagentur Freiburg | PlasticSurf';
const pageDescription = 'Kreativagentur aus Freiburg: Über 20 Referenzprojekte aus eCommerce, Verpackungsdesign, Marketing und WebDesign. Echte Erlebnisse von PlasticSurf.';

type Ref = {
  client: string;
  project: string;
  category: string;
  gradient: string;
  image?: string;
  alt?: string;
  size: 'large' | 'medium';
  href?: string;
};

// Große/Featured Referenzen → Bento-Grid
