    project: 'Marketing & Design',
    category: 'WebDesign',
    gradient: 'linear-gradient(135deg, #2d0010 0%, #4a0020 50%, #3d0015 100%)',
    image: '/images/erlebnisse/roses-juice-webdesign-marketing-design.webp',
    alt: "Rose's Juice WebDesign – Marketing und Design",
    size: 'medium',
  },
  {
    client: 'TEAHOUSE EXCLUSIVES',
    project: 'Stilvoll, Funktional & Mehrsprachig',
    category: 'WebDesign',
    gradient: 'linear-gradient(135deg, #0f1a0f 0%, #1a2d1a 50%, #0a1f0a 100%)',
    image: '/images/erlebnisse/teahouse-exclusives-webdesign.webp',
    alt: 'TEAHOUSE EXCLUSIVES WebDesign – Stilvoll, Funktional und Mehrsprachig',
    size: 'medium',
    href: '/erlebnisse/tee-von-teahouse-exclusives',
  },
  {
    client: 'Vertriebsagentur WunderHand',
    project: 'Nachhaltige Lebensmittel',
    category: 'WebDesign',
