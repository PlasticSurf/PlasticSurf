const allRefs = [...featuredRefs, ...smallRefs];
const itemListSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  'name': 'Referenzen – Kreativagentur Freiburg | PlasticSurf',
  'description': pageDescription,
  'numberOfItems': allRefs.length,
  'itemListElement': allRefs.map((ref, i) => ({
    '@type': 'ListItem',
    'position': i + 1,
    'name': `${ref.client} – ${ref.project}`,
    ...(ref.href ? { 'url': `https://www.plasticsurf.de${ref.href}` } : {}),
  })),
});
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  image="/images/erlebnisse-hero-desktop.webp"
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />
  <script type="application/ld+json" set:html={itemListSchema} />

  <!-- Wrapper: Hintergrundbild läuft nach unten über den Hero hinaus -->
  <div class="relative" style="overflow: clip;">

    <!-- Hintergrundbild auf Page-Ebene (höher als der Hero-Container) -->
    <picture class="absolute inset-x-0 top-0 w-full pointer-events-none select-none" style="height: 140vh; z-index: 0;" aria-hidden="true">
      <source media="(min-width: 1024px)" srcset="/images/erlebnisse-hero-desktop.webp" type="image/webp" />
      <source media="(min-width: 768px)"  srcset="/images/erlebnisse-hero-tablet.webp"  type="image/webp" />
      <img
        src="/images/erlebnisse-hero-mobile.webp"
        alt=""
        class="w-full h-full object-none object-top"
        loading="eager"
      />
    </picture>

    <!-- Fade-Overlay: Bild läuft sanft in den Seitenhintergrund aus -->
    <div class="absolute inset-x-0 pointer-events-none select-none" style="top: 60vh; height: 80vh; background: linear-gradient(to bottom, transparent, #080D19); z-index: 1;" aria-hidden="true" />

    <!-- HeroZone ohne internes Bild (Klasse hero-zone--image unterdrückt Dot-Textur) -->
    <div style="position: relative; z-index: 2;">
      <HeroZone class="hero-zone--image">
        <Hero
          headline='<span class="text-primary">Resonanz</span> statt Rauschen.'
          subline="Wo Momente Form annehmen."
          layout="left"
          eyebrow="Referenzen – Kreativagentur Freiburg"
        >
          <p class="reveal reveal-delay-300 mt-8 font-body text-base md:text-lg text-text/80 leading-relaxed max-w-3xl">
            In einer Zeit der unendlichen Signale ist echte Aufmerksamkeit das kostbarste Gut. Wir gestalten Erlebnisse als Antwort auf die Frage nach dem Bleibenden. Bei Plastic Surf werden Gedanken zu Formen und Interaktionen zu Erfahrungen, die Orientierung bieten. Wir bauen keine Fassaden, sondern Identität, die man erleben kann. Durch die Verbindung von klarer Struktur und ästhetischer Intelligenz entstehen Momente des Innehaltens – leise, wirkungsvoll und mit der nötigen Ruhe, um im algorithmischen Lärm der Gegenwart wirklich gehört zu werden.
          </p>
        </Hero>
      </HeroZone>
    </div>

  <!-- Bento-Grid (transparent, damit Bild durchscheinen kann) -->
  <section style="background: transparent; position: relative; z-index: 2;">
    <div class="container-custom">
    <div class="bento-grid">
      {featuredRefs.map((ref) => {
        const Tag = ref.href ? 'a' : 'article';
        return (
          <Tag
            class={`bento-card bento-card-${ref.size}${ref.href ? ' bento-card--link' : ''}`}
            {...(ref.href ? { href: ref.href, title: `${ref.category}: ${ref.client} – ${ref.project}` } : {})}
          >
            <div
              class="bento-card__bg"
              style={`background: ${ref.gradient};`}
            />
            {ref.image && (
              <img
                src={ref.image}
                alt={ref.alt ?? ref.client}
                class="bento-card__bg"
                loading="lazy"
              />
            )}
            <div class="bento-card__overlay" />
            <div class="bento-card__content">
              <span class="bento-card__category">{ref.category}</span>
              <h3 class="bento-card__client">{ref.client}</h3>
              <p class="bento-card__project">{ref.project}</p>
            </div>
          </Tag>
        );
      })}
    </div>
    </div>
  </section>

  </div><!-- /Wrapper Hintergrundbild -->

  <!-- Slider: Kleinere Projekte -->
  <section class="section-padding bg-background">
    <div class="container-custom">
      <div class="text-center mb-8">
        <h2 class="reveal font-primary text-[3.125rem] font-black leading-tight mb-1">Weitere Projekte</h2>
        <p class="reveal reveal-delay-200 font-secondary text-2xl text-[#927350] mb-8">
          Noch mehr Erlebnisse aus unserem Portfolio
        </p>
      </div>

      <div class="reveal reveal-delay-300">
        <div class="ref-slider-track" id="refSliderTrack">
          {smallRefs.map((ref) => {
            const SliderTag = ref.href ? 'a' : 'article';
            return (
              <SliderTag
                class={`ref-slider-card${ref.href ? ' bento-card--link' : ''}`}
                {...(ref.href ? { href: ref.href, title: `${ref.category}: ${ref.client} – ${ref.project}`, style: 'cursor: pointer;' } : {})}
              >
                <div
                  class="bento-card__bg"
                  style={`background: ${ref.gradient};`}
                />
                {ref.image && (
                  <img
                    src={ref.image}
                    alt={ref.alt ?? ref.client}
                    class="bento-card__bg"
                    loading="lazy"
                  />
                )}
                <div class="bento-card__overlay" />
                <div class="bento-card__content">
                  <span class="bento-card__category">{ref.category}</span>
                  <h3 class="bento-card__client" style="font-size: 1.1rem;">{ref.client}</h3>
                  <p class="bento-card__project">{ref.project}</p>
                </div>
              </SliderTag>
            );
          })}
        </div>

        <!-- Dot-Navigation -->
        <div class="slider-dots" id="refSliderDots" role="tablist" aria-label="Slider Navigation">
          {smallRefs.map((_, i) => (
            <button
              class={`slider-dot${i === 0 ? ' active' : ''}`}
              data-index={i}
              aria-label={`Projekt ${i + 1}`}
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
            />
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section-padding bg-primary/5">
    <div class="container-custom">
      <div class="text-center mb-12">
        <h2 class="reveal font-primary text-[3.125rem] font-black leading-tight mb-1">Kundenstimmen</h2>
        <p class="reveal reveal-delay-200 font-secondary text-2xl text-[#927350] max-w-2xl mx-auto mb-8">
          Was unsere Kunden über die Zusammenarbeit sagen
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <blockquote class="reveal reveal-delay-100 p-6 bg-white/5 rounded-lg border border-white/10">
          <p class="font-body text-base text-text/80 italic leading-relaxed mb-4">
            "Die Zusammenarbeit war außergewöhnlich professionell. Das Ergebnis
            übertrifft unsere Erwartungen bei Weitem."
          </p>
          <footer class="font-primary text-primary">
            — Max Mustermann, CEO Musterkunde GmbH
          </footer>
        </blockquote>

        <blockquote class="reveal reveal-delay-300 p-6 bg-white/5 rounded-lg border border-white/10">
          <p class="font-body text-base text-text/80 italic leading-relaxed mb-4">
            "Endlich ein Partner, der digitale Strategien ganzheitlich denkt
            und umsetzt. Absolut empfehlenswert!"
          </p>
          <footer class="font-primary text-primary">
            — Maria Beispiel, Marketing Leiterin Beispiel AG
          </footer>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-padding-lg bg-background">
    <div class="container-custom text-center">
      <h2 class="reveal font-primary text-[3.125rem] font-black leading-tight mb-1">
        Werden Sie Teil unserer Erfolgsgeschichte
      </h2>
      <p class="reveal reveal-delay-200 font-secondary text-2xl text-[#927350] max-w-xl mx-auto mb-8">
        Lassen Sie uns gemeinsam Ihr nächstes Projekt realisieren.
      </p>
      <a href="/kontakt" class="reveal reveal-delay-400 btn-primary">
        Jetzt anfragen
      </a>
    </div>
  </section>

  <script>
    const track = document.getElementById('refSliderTrack');
    const dotsContainer = document.getElementById('refSliderDots');

    if (track && dotsContainer) {
      const dots = Array.from(dotsContainer.querySelectorAll<HTMLButtonElement>('.slider-dot'));
      const cards = Array.from(track.querySelectorAll<HTMLElement>('.ref-slider-card'));

      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          const card = cards[i];
          if (card) {
            track.scrollTo({ left: card.offsetLeft - track.offsetLeft, behavior: 'smooth' });
          }
        });
      });

      let scrollTimer: ReturnType<typeof setTimeout> | null = null;
      track.addEventListener('scroll', () => {
        if (scrollTimer) clearTimeout(scrollTimer);
        scrollTimer = setTimeout(() => {
          const trackLeft = track.scrollLeft;
          let closest = 0;
          let minDist = Infinity;
          cards.forEach((card, i) => {
            const dist = Math.abs(card.offsetLeft - track.offsetLeft - trackLeft);
            if (dist < minDist) { minDist = dist; closest = i; }
          });
          dots.forEach((d, i) => {
            d.classList.toggle('active', i === closest);
            d.setAttribute('aria-selected', i === closest ? 'true' : 'false');
          });
        }, 50);
      });
    }
  </script>
</BaseLayout>
