---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { generateBreadcrumbSchema } from '../../lib/seo';
import ErlebnisCTA from '../../components/global/ErlebnisCTA.astro';

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: 'https://www.plasticsurf.de/' },
  { name: 'Erlebnisse', url: 'https://www.plasticsurf.de/erlebnisse' },
  { name: 'KaffeeShop 24 Online Shop', url: 'https://www.plasticsurf.de/erlebnisse/kaffeeshop-24-online-shop' },
]);
---

<BaseLayout
  title="KaffeeShop 24 Online Shop – eCommerce B2B & B2C – PlasticSurf"
  description="eCommerce B2B & B2C Lösung für KaffeeShop 24 – mit ERP & CRM-Anbindung, UX-Design, SEO, Online Marketing & Content Strategie ..."
  image="/images/erlebnisse/kaffeeshop-24-online-shop/kaffeeshop-24-ecommerce-hero-desktop.webp"
  canonicalURL="https://www.plasticsurf.de/erlebnisse/kaffeeshop-24-online-shop/"
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- 1. Hero: flexibles Vollbild, natürliche Höhe -->
  <picture>
    <source media="(min-width: 1024px)" srcset="/images/erlebnisse/kaffeeshop-24-online-shop/kaffeeshop-24-ecommerce-hero-desktop.webp" type="image/webp" />
    <source media="(min-width: 768px)"  srcset="/images/erlebnisse/kaffeeshop-24-online-shop/kaffeeshop-24-ecommerce-hero-tablet.webp"  type="image/webp" />
    <img
      src="/images/erlebnisse/kaffeeshop-24-online-shop/kaffeeshop-24-ecommerce-hero-mobile.webp"
      alt="KaffeeShop 24 eCommerce Online Shop – B2B & B2C Plattform mit ERP-Anbindung"
      class="w-full h-auto block"
      loading="eager"
    />
  </picture>

  <!-- 2. Breadcrumb -->
  <div class="bg-background">
    <div class="container-custom py-3">
      <nav aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 font-body text-xs text-text/50">
          <li>
            <a href="/" class="hover:text-primary transition-colors" aria-label="Startseite">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 inline-block" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7A1 1 0 003 11h1v6a1 1 0 001 1h4v-4h2v4h4a1 1 0 001-1v-6h1a1 1 0 00.707-1.707l-7-7z" />
              </svg>
            </a>
          </li>
          <li class="text-text/30">/</li>
          <li><a href="/erlebnisse" class="hover:text-primary transition-colors">Erlebnisse</a></li>
          <li class="text-text/30">/</li>
          <li class="text-text/70">KaffeeShop 24</li>
        </ol>
      </nav>
    </div>
  </div>

  <!-- 3. Zweispalter: Links langes Bild | Rechts vollständiger Text -->
  <section class="section-padding bg-background">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">

        <!-- Linke Spalte: langes Shop-Layout-Bild -->
        <div class="flex flex-col gap-6">
          <img
            src="/images/erlebnisse/kaffeeshop-24-online-shop/kaffeeshop-24-shop-layout.webp"
            alt="KaffeeShop 24 Shop Layout – eCommerce Design für B2B & B2C"
            class="w-full reveal"
            loading="eager"
          />
        </div>

        <!-- Rechte Spalte: vollständiger Text -->
        <div>
          <p class="reveal font-secondary text-primary text-sm uppercase tracking-widest mb-3">
            eCommerce & Design
          </p>
          <h1 class="reveal reveal-delay-100 font-primary text-[3.125rem] font-black leading-tight mb-6">
            Mein Beitrag zum eCommerce B2B &amp; B2C für KaffeeShop 24
          </h1>
          <p class="reveal reveal-delay-200 font-body text-base text-text/80 leading-relaxed mb-6">
            Für KaffeeShop 24 habe ich die komplette <strong>eCommerce</strong>-Lösung für <strong>B2B &amp; B2C</strong> entwickelt und umgesetzt. Ziel war es, eine leistungsstarke und benutzerfreundliche Online-Plattform zu schaffen, die den Kunden ein reibungsloses Einkaufserlebnis bietet – unabhängig davon, ob sie als Endkunden oder Geschäftspartner einkaufen. Dabei stand nicht nur das Design im Fokus, sondern auch die technische Integration in bestehende Systeme.
          </p>
          <p class="reveal reveal-delay-300 font-body text-sm text-text/50 leading-relaxed mb-10">
            Zusammenarbeit 2009 bis 2018
          </p>

          <h2 class="reveal reveal-delay-400 font-primary text-3xl font-black leading-tight mb-4">
            Ein eCommerce-System für Genuss &amp; Vielfalt
          </h2>
          <p class="reveal reveal-delay-500 font-body text-base text-text/80 leading-relaxed mb-4">
            <strong>KaffeeShop 24</strong> bietet eine außergewöhnliche Vielfalt an handgerösteten Gourmetkaffees sowie eine breite Auswahl an Spezialitäten aus aller Welt – von Tee und Trinkschokolade bis hin zu Feinkost und Zubehör. Um dieses umfangreiche Sortiment optimal zu präsentieren, habe ich den Online-Shop sowohl für B2C-Kunden als auch für B2B-Partner optimiert. Dazu gehörten:
          </p>
          <ul class="reveal reveal-delay-500 font-body text-base text-text/80 leading-relaxed list-disc list-outside ml-5 space-y-3 mb-10">
            <li>Entwicklung eines maßgeschneiderten <strong>eCommerce</strong>-Konzepts</li>
            <li><strong>Layout &amp; Design</strong>, das Funktionalität und Ästhetik vereint</li>
            <li><strong>ERP &amp; CRM</strong>-Anbindung, um Bestell- und Lagerprozesse effizient zu steuern</li>
            <li>Implementierung eines modernen CSS Frameworks für optimale Performance</li>
          </ul>

          <h2 class="reveal font-primary text-3xl font-black leading-tight mb-4">
            eCommerce B2B B2C – Mehr als nur ein Shop
          </h2>
          <p class="reveal reveal-delay-100 font-body text-base text-text/80 leading-relaxed mb-4">
            Ein erfolgreicher Online-Shop benötigt mehr als nur eine attraktive Oberfläche. Deshalb habe ich für KaffeeShop 24 eine ganzheitliche Strategie entwickelt, die über die technische Umsetzung hinausgeht:
          </p>
          <ul class="reveal reveal-delay-100 font-body text-base text-text/80 leading-relaxed list-disc list-outside ml-5 space-y-3 mb-8">
            <li><strong>Analyse &amp; Optimierung</strong>, um die Benutzerfreundlichkeit kontinuierlich zu verbessern</li>
            <li><strong>Online Marketing</strong> mit gezielten Kampagnen für maximale Sichtbarkeit</li>
            <li><strong>Suchmaschinenoptimierung</strong> (SEO) für bessere Rankings, sowohl On- als auch Off-Page</li>
            <li><strong>Content &amp; Crossmedia Marketing</strong>, um Kunden gezielt anzusprechen und die Marke zu stärken</li>
          </ul>
          <p class="reveal reveal-delay-200 font-body text-base text-text/80 leading-relaxed">
            Durch diese Maßnahmen konnte eine nachhaltige und zukunftsfähige eCommerce-Lösung geschaffen werden, die KaffeeShop 24 optimal im digitalen Markt positioniert – für Endverbraucher wie auch für Geschäftskunden.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- 4. CTA -->
  <ErlebnisCTA />

</BaseLayout>
