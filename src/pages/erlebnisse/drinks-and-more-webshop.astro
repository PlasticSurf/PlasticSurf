---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { generateBreadcrumbSchema } from '../../lib/seo';
import ErlebnisCTA from '../../components/global/ErlebnisCTA.astro';

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: 'https://www.plasticsurf.de/' },
  { name: 'Erlebnisse', url: 'https://www.plasticsurf.de/erlebnisse' },
  { name: 'Drinks & More WebShop', url: 'https://www.plasticsurf.de/erlebnisse/drinks-and-more-webshop' },
]);
---

<BaseLayout
  title="Drinks & More WebShop – eCommerce & Design – PlasticSurf"
  description="Ich habe Drinks and More mit Marketing, Design & eCommerce B2B, B2C unterstützt. Entdecke meine Expertise in Online-Marketing & SEO!"
  image="/images/erlebnisse/drinks-and-more-webshop/drinks-and-more-webshop-ecommerce-hero-desktop.webp"
  canonicalURL="https://www.plasticsurf.de/erlebnisse/drinks-and-more-webshop/"
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- 1. Hero -->
  <picture>
    <source media="(min-width: 1024px)" srcset="/images/erlebnisse/drinks-and-more-webshop/drinks-and-more-webshop-ecommerce-hero-desktop.webp" type="image/webp" />
    <source media="(min-width: 768px)"  srcset="/images/erlebnisse/drinks-and-more-webshop/drinks-and-more-webshop-ecommerce-hero-tablet.webp"  type="image/webp" />
    <img
      src="/images/erlebnisse/drinks-and-more-webshop/drinks-and-more-webshop-ecommerce-hero-mobile.webp"
      alt="Drinks and More WebShop – eCommerce B2B & B2C mit Magento, Marketing & Design aus Freiburg"
      class="w-full h-auto block"
      loading="eager"
    />
  </picture>

  <!-- 2. Breadcrumb -->
  <div class="bg-background">
    <div class="container-custom py-3">
      <nav aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 font-body text-xs text-text/50">
          <li>
            <a href="/" class="hover:text-primary transition-colors" aria-label="Startseite">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 inline-block" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7A1 1 0 003 11h1v6a1 1 0 001 1h4v-4h2v4h4a1 1 0 001-1v-6h1a1 1 0 00.707-1.707l-7-7z" />
              </svg>
            </a>
          </li>
          <li class="text-text/30">/</li>
          <li><a href="/erlebnisse" class="hover:text-primary transition-colors">Erlebnisse</a></li>
          <li class="text-text/30">/</li>
          <li class="text-text/70">Drinks & More</li>
        </ol>
      </nav>
    </div>
  </div>

  <!-- 3. Zweispalter: Links Bild | Rechts H1 + Text -->
  <section class="section-padding bg-background">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">

        <!-- Linke Spalte: iPad-Ansichten -->
        <div class="flex flex-col gap-6">
          <img
            src="/images/erlebnisse/drinks-and-more-webshop/drinks-and-more-webshop-ipad-ansicht.webp"
            alt="Drinks and More Website – iPad-Ansicht des eCommerce Webshops"
            class="w-full reveal"
            loading="eager"
          />
          <img
            src="/images/erlebnisse/drinks-and-more-webshop/drinks-and-more-webshop-ipad.webp"
            alt="Drinks and More Website – responsive Ansicht auf dem iPad"
            class="w-full reveal reveal-delay-100"
            loading="lazy"
          />
        </div>

        <!-- Rechte Spalte: H1 + Text -->
        <div>
          <p class="reveal font-secondary text-primary text-sm uppercase tracking-widest mb-3">
            eCommerce & Design
          </p>
          <h1 class="reveal reveal-delay-100 font-primary text-[3.125rem] font-black leading-[1.1] mb-6">
            Drinks and More
          </h1>
          <h2 class="reveal reveal-delay-200 font-primary text-3xl font-black leading-tight mb-4">
            Die Innovationsschmiede für Trendgetränke
          </h2>
          <p class="reveal reveal-delay-300 font-body text-base text-text/80 leading-relaxed mb-10">
            Seit der Gründung im Jahr 2002 in Hamburg steht Drinks and More für Mut, Ehrgeiz und ein tiefes Verständnis für den Getränkemarkt. Als Innovationsführer im Bereich nichtalkoholischer Trendgetränke verfolgt das Unternehmen eine klare Vision: "We want to become the leading Sales & Marketing company for innovative imported premium beverages in Germany." Der Erfolg basiert darauf, frühzeitig Markttrends zu erkennen und mit strategischer Weitsicht darauf zu reagieren.
          </p>

          <h2 class="reveal reveal-delay-400 font-primary text-3xl font-black leading-tight mb-4">
            Mein Beitrag: Marketing, Design & eCommerce-Lösungen
          </h2>
          <p class="reveal reveal-delay-500 font-body text-base text-text/80 leading-relaxed mb-6">
            Für Drinks and More habe ich als <strong>Werbeagentur aus Freiburg</strong> umfassende Marketing Design- und eCommerce-Projekte umgesetzt. Dabei lag mein Fokus auf:
          </p>
          <ul class="reveal reveal-delay-500 font-body text-base text-text/80 leading-relaxed mb-8 space-y-2">
            <li class="flex items-start gap-3"><span class="text-primary mt-1">→</span><span>Content Management für eine starke Markenkommunikation</span></li>
            <li class="flex items-start gap-3"><span class="text-primary mt-1">→</span><span>eCommerce-Lösungen für B2B & B2C angefangen im Jahr 2010 basierend auf dem Magento Shop von Adobe mit Mehrsprachigkeit</span></li>
            <li class="flex items-start gap-3"><span class="text-primary mt-1">→</span><span>Hochwertiges Design, das Markenwerte und Trends visuell transportiert</span></li>
            <li class="flex items-start gap-3"><span class="text-primary mt-1">→</span><span>Online Marketing & Suchmaschinenoptimierung (SEO) für eine höhere Reichweite</span></li>
            <li class="flex items-start gap-3"><span class="text-primary mt-1">→</span><span>Artikel- und Contentmanagement, um relevante Inhalte strategisch zu positionieren</span></li>
          </ul>
        </div>

      </div>
    </div>
  </section>

  <!-- 4. Weitere Inhalte: Vollbreite -->
  <section class="section-padding bg-background border-t border-text/5">
    <div class="container-custom">

      <h2 class="reveal font-primary text-3xl font-black leading-tight mb-6">
        Drinks and More Marketing Design – Zukunftsorientiert & Erfolgsfokussiert
      </h2>
      <p class="reveal reveal-delay-100 font-body text-base text-text/80 leading-relaxed mb-12">
        Mein Anspruch im <strong>Drinks and More Marketing und Design</strong> war es, eine starke Verbindung zwischen Innovation und Strategie zu schaffen. Das bedeutet, Marken nicht nur visuell ansprechend zu präsentieren, sondern auch nachhaltig in der digitalen Welt zu etablieren. Durch gezielte Online-Marketing-Maßnahmen, optimierte eCommerce-Plattformen und strategisches SEO konnte ich dazu beitragen, die Marktposition von Drinks and More weiter zu stärken.
      </p>

    </div>
  </section>

  <!-- 5. Galerie -->
  <section class="section-padding bg-background border-t border-text/5">
    <div class="container-custom">
      <h2 class="reveal font-primary text-3xl font-black leading-tight mb-6">
        Einblicke in den WebShop
      </h2>
      <p class="reveal reveal-delay-100 font-body text-base text-text/80 leading-relaxed mb-10 max-w-2xl">
        Der Drinks and More WebShop vereint modernes Design mit einer durchdachten Nutzererfahrung – optimiert für B2B- und B2C-Kunden gleichermaßen.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <img
          src="/images/erlebnisse/drinks-and-more-webshop/drinks-and-more-webshop-website.webp"
          alt="Drinks and More WebShop – Website-Ansicht mit Produktkatalog"
          class="w-full reveal"
          loading="lazy"
        />
        <img
          src="/images/erlebnisse/drinks-and-more-webshop/drinks-and-more-webshop-screenshot.webp"
          alt="Drinks and More WebShop – Screenshot der eCommerce Plattform"
          class="w-full reveal reveal-delay-100"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <ErlebnisCTA />

</BaseLayout>
