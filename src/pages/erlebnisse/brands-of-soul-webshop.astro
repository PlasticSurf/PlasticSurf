---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { generateBreadcrumbSchema } from '../../lib/seo';
import ErlebnisCTA from '../../components/global/ErlebnisCTA.astro';

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: 'https://www.plasticsurf.de/' },
  { name: 'Erlebnisse', url: 'https://www.plasticsurf.de/erlebnisse' },
  { name: 'Brands of Soul WebShop', url: 'https://www.plasticsurf.de/erlebnisse/brands-of-soul-webshop' },
]);
---

<BaseLayout
  title="Brands of Soul WebShop – PlasticSurf"
  description="Brands of Soul Shopware WebShop beim Shop Usability Award 2015 – Nominierung in der Kategorie Bester Markenshop."
  image="/images/erlebnisse/brands-of-soul-webshop/brands-of-soul-ecommerce-hero-desktop.webp"
  canonicalURL="https://www.plasticsurf.de/erlebnisse/brands-of-soul-webshop/"
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- 1. Hero -->
  <picture>
    <source media="(min-width: 1024px)" srcset="/images/erlebnisse/brands-of-soul-webshop/brands-of-soul-ecommerce-hero-desktop.webp" type="image/webp" />
    <source media="(min-width: 768px)"  srcset="/images/erlebnisse/brands-of-soul-webshop/brands-of-soul-ecommerce-hero-tablet.webp"  type="image/webp" />
    <img
      src="/images/erlebnisse/brands-of-soul-webshop/brands-of-soul-ecommerce-hero-mobile.webp"
      alt="Brands of Soul WebShop – Shopware Shop, nominiert beim Shop Usability Award 2015"
      class="w-full h-auto block"
      loading="eager"
    />
  </picture>

  <!-- 2. Breadcrumb -->
  <div class="bg-background">
    <div class="container-custom py-3">
      <nav aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 font-body text-xs text-text/50">
          <li>
            <a href="/" class="hover:text-primary transition-colors" aria-label="Startseite">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 inline-block" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7A1 1 0 003 11h1v6a1 1 0 001 1h4v-4h2v4h4a1 1 0 001-1v-6h1a1 1 0 00.707-1.707l-7-7z" />
              </svg>
            </a>
          </li>
          <li class="text-text/30">/</li>
          <li><a href="/erlebnisse" class="hover:text-primary transition-colors">Erlebnisse</a></li>
          <li class="text-text/30">/</li>
          <li class="text-text/70">Brands of Soul</li>
        </ol>
      </nav>
    </div>
  </div>

  <!-- 3. Zweispalter -->
  <section class="section-padding bg-background">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-start">

        <!-- Linke Spalte: Bilder -->
        <div class="flex flex-col gap-6">
          <img
            src="/images/erlebnisse/brands-of-soul-webshop/brands-of-soul-webshop-ansicht.webp"
            alt="Brands of Soul WebShop – Produktansicht im Shopware Shop"
            class="w-full reveal"
            loading="eager"
          />
        </div>

        <!-- Rechte Spalte: H1 + Text -->
        <div>
          <p class="reveal font-secondary text-primary text-sm uppercase tracking-widest mb-3">
            eCommerce
          </p>
          <h1 class="reveal reveal-delay-100 font-primary text-[3.125rem] font-black leading-tight mb-6">
            Brands of Soul WebShop – Intuitiv, Nutzerfreundlich & Erfolgreich
          </h1>
          <p class="reveal reveal-delay-200 font-body text-base text-text/80 leading-relaxed mb-10">
            Ein erfolgreicher Online-Shop muss vor allem eins sein: einfach und intuitiv zu bedienen. Denn was nützt das beste Sortiment, wenn Kunden an einer schlechten Usability scheitern? Brands of Soul wollte genau das vermeiden – und investierte gezielt in eine Optimierung seines Webshops.
          </p>

          <h2 class="reveal reveal-delay-300 font-primary text-3xl font-black leading-tight mb-4">
            Von Magento zu Shopware: Ein Upgrade mit spürbarem Effekt
          </h2>
          <p class="reveal reveal-delay-400 font-body text-base text-text/80 leading-relaxed">
            Mit der Portierung von Magento auf Shopware wurde nicht nur ein modernes, responsives Design eingeführt, sondern auch zahlreiche Usability-Hürden beseitigt. Der Wechsel ermöglichte zudem eine nahtlose Integration des B2B- in den B2C-Shop, sodass Geschäftskunden und Endverbraucher nun gleichermaßen von einer optimierten Nutzererfahrung profitieren.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- 4. Weitere Inhalte -->
  <section class="section-padding bg-background border-t border-text/5">
    <div class="container-custom">

      <h2 class="reveal font-primary text-3xl font-black leading-tight mb-6">
        Shop Usability Award 2015: Eine besondere Auszeichnung
      </h2>
      <p class="reveal reveal-delay-100 font-body text-base text-text/80 leading-relaxed mb-6">
        Große Freude: Der Brands of Soul WebShop wurde 2015 für den renommierten Shop Usability Award nominiert – in der Kategorie „Bester Markenshop"!
      </p>
      <ul class="reveal reveal-delay-200 font-body text-base text-text/80 leading-relaxed mb-6 space-y-2">
        <li class="flex items-start gap-3"><span class="text-primary mt-1">→</span><span>534 Bewerbungen gingen für 14 Kategorien mit jeweils 5 Nominierungen ein.</span></li>
        <li class="flex items-start gap-3"><span class="text-primary mt-1">→</span><span>Eine Fachjury aus führenden eCommerce-Experten bewertete die Shops nach einem detaillierten Punktekatalog.</span></li>
        <li class="flex items-start gap-3"><span class="text-primary mt-1">→</span><span>Brands of Soul schaffte es unter die besten Markenshops – ein Ritterschlag in der Branche!</span></li>
      </ul>
      <p class="reveal reveal-delay-300 font-body text-base text-text/80 leading-relaxed mb-12">
        Besonders spannend: Die Anmeldung kam eher zufällig zustande. Shopware übernahm freundlicherweise die Teilnahmegebühr, sodass ich unverhofft in den Wettbewerb rutschte – und direkt eine Nominierung erhielt! Ein toller Erfolg und eine großartige Bestätigung für die strategische Neuausrichtung des Shops.
      </p>

      <h2 class="reveal font-primary text-3xl font-black leading-tight mb-6">
        Leistungen: Komplettbetreuung für ein erfolgreiches eCommerce-Projekt
      </h2>
      <p class="reveal reveal-delay-100 font-body text-base text-text/80 leading-relaxed mb-6">
        Die Optimierung und Weiterentwicklung des Shops umfasste eine Vielzahl an Maßnahmen – von der technischen Basis bis hin zur Conversion-Optimierung.
      </p>
      <ul class="reveal reveal-delay-200 font-body text-base text-text/80 leading-relaxed mb-12 space-y-2">
        <li class="flex items-start gap-3"><span class="text-primary mt-1">✓</span><span><strong>Konzeption & Branding</strong> – Eine starke Markenwelt für ein einzigartiges Shopping-Erlebnis</span></li>
        <li class="flex items-start gap-3"><span class="text-primary mt-1">✓</span><span><strong>Performance Marketing</strong> – Strategien für maximale Reichweite und Umsatzsteigerung</span></li>
        <li class="flex items-start gap-3"><span class="text-primary mt-1">✓</span><span><strong>B2C & B2B-Integration</strong> – Eine durchdachte Plattform für Endkunden und Geschäftspartner</span></li>
        <li class="flex items-start gap-3"><span class="text-primary mt-1">✓</span><span><strong>Blog & Magazin</strong> – Content-Marketing für eine nachhaltige Kundenbindung</span></li>
        <li class="flex items-start gap-3"><span class="text-primary mt-1">✓</span><span><strong>ERP & CRM-Anbindung</strong> – Optimierung der internen Geschäftsprozesse</span></li>
        <li class="flex items-start gap-3"><span class="text-primary mt-1">✓</span><span><strong>Amazon-Anbindung</strong> – Erweiterung der Vertriebskanäle für mehr Reichweite</span></li>
        <li class="flex items-start gap-3"><span class="text-primary mt-1">✓</span><span><strong>Conversion-Optimierung</strong> – Über 9% Conversion-Rate durch gezielte Maßnahmen!</span></li>
      </ul>

      <h2 class="reveal font-primary text-3xl font-black leading-tight mb-4">
        Fazit: Erfolg durch Nutzerzentrierung
      </h2>
      <p class="reveal reveal-delay-100 font-body text-base text-text/80 leading-relaxed">
        Die Umstellung auf Shopware, eine verbesserte Usability und eine durchdachte eCommerce-Strategie haben Brands of Soul nicht nur einen erfolgreichen Shop-Relaunch beschert – sondern auch eine Nominierung beim Shop Usability Award 2015 eingebracht. Das zeigt: Ein durchdachtes UX-Konzept, modernes Design und optimierte Prozesse sind der Schlüssel zu nachhaltigem eCommerce-Erfolg.
      </p>

    </div>
  </section>

  <!-- 5. Galerie -->
  <section class="section-padding bg-background border-t border-text/5">
    <div class="container-custom">
      <h2 class="reveal font-primary text-3xl font-black leading-tight mb-6">
        Einblicke in den Shop
      </h2>
      <p class="reveal reveal-delay-100 font-body text-base text-text/80 leading-relaxed mb-10 max-w-2xl">
        Der Brands of Soul WebShop überzeugt mit einem modernen, markentypischen Design – vom Produktlisting über die Detailseiten bis hin zur reibungslosen Checkout-Experience.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <img
          src="/images/erlebnisse/brands-of-soul-webshop/brands-of-soul-online-shop.webp"
          alt="Brands of Soul Online Shop – Kategorieansicht im Shopware WebShop"
          class="w-full reveal"
          loading="lazy"
        />
        <img
          src="/images/erlebnisse/brands-of-soul-webshop/brands-of-soul-online-webshop.webp"
          alt="Brands of Soul Online WebShop – Produktdetailseite im Shopware Shop"
          class="w-full reveal reveal-delay-100"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <ErlebnisCTA />

</BaseLayout>
