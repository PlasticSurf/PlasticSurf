---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { generateBreadcrumbSchema } from '../../lib/seo';
import Hero from '../../components/global/Hero.astro';
import HeroZone from '../../components/global/HeroZone.astro';
import KontaktSection from '../../components/global/KontaktSection.astro';

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: 'https://www.plasticsurf.de/' },
  { name: 'Lösungen', url: 'https://www.plasticsurf.de/loesungen' },
  { name: 'Der Performance Audit', url: 'https://www.plasticsurf.de/loesungen/der-performance-audit' },
]);

const serviceSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Performance Audit & KI-Fahrplan",
  "provider": { "@type": "Organization", "name": "PlasticSurf" },
  "areaServed": "Freiburg im Breisgau",
  "description": "Digitale Standortbestimmung: Daten, Kanäle und Performance in einem klaren Lagebild – mit priorisierten Handlungsempfehlungen."
});
---

<BaseLayout
  title="Performance Audit & KI-Fahrplan – PlasticSurf Freiburg"
  description="Kreativagentur Freiburg: Der Performance Audit von PlasticSurf verdichtet Daten, Kanäle und Wirkung zu einem klaren Lagebild – mit priorisierten Schritten."
  image="/images/performance-audit-ki-fahrplan-og.webp"
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />
  <script type="application/ld+json" set:html={serviceSchema} />

  <HeroZone backgroundImage={{
    desktop: '/images/performance-audit-ki-fahrplan-hero-desktop.webp',
    tablet:  '/images/performance-audit-ki-fahrplan-hero-tablet.webp',
    mobile:  '/images/performance-audit-ki-fahrplan-hero-mobile.webp',
  }}>
    <Hero
      eyebrow="Performance Audit & KI-Fahrplan"
      headline="Der Performance Audit"
      subline="Orientierung, die Wachstum führbar macht"
      layout="left"
    >
      <p class="reveal reveal-delay-200 mt-8 font-body text-base text-text/80 leading-relaxed max-w-3xl">
        Ihr Geschäft wächst – und genau deshalb lohnt sich der Blick mit Anspruch: Wo entsteht echte Wirkung, wo bleibt Wert liegen, wo steckt ungenutztes Potenzial? Der Performance Audit verdichtet alles zu einem klaren Lagebild. Prioritäten werden sichtbar, Ansatzpunkte treten hervor, nächste Schritte werden eindeutig. So beginnt ein Weg, der sitzt: klar priorisiert, ruhig geführt, tragfähig für die Umsetzung.
      </p>
      <a
        href="#kontakt"
        title="Performance Audit anfragen – PlasticSurf Freiburg"
        class="reveal reveal-delay-400 btn-primary mt-10 inline-flex items-center gap-2"
      >
        Neue Karten entdecken
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </a>
    </Hero>

    <!-- Sektion 1: Der KI-Fahrplan -->
    <section class="section-padding bg-background">
      <div class="container-custom">
        <div class="max-w-3xl">
          <h2 class="reveal font-primary text-[3.125rem] font-black leading-tight mb-1">Der KI-Fahrplan.</h2>
          <p class="reveal reveal-delay-100 font-secondary text-2xl text-[#927350] mb-8">Präzision, die sich leicht anfühlt.</p>
          <p class="reveal reveal-delay-200 font-body text-base text-text/80 leading-relaxed">
            KI bündelt die Signale aus Ihrem System und bringt Ordnung in Komplexität. Was vorher wie viele Möglichkeiten aussieht, wird zu ruhiger Orientierung – klar, nachvollziehbar, ohne Umwege. Das Ergebnis ist kein Report, sondern eine klare Linie: Prioritäten, nächste Schritte, saubere Begründung. Richtung fühlt sich wieder leicht an und bleibt umsetzbar für Team und Budget.
          </p>
        </div>
      </div>
    </section>

    <!-- Sektion 2: Der Moment, in dem alles zusammenkommt -->
    <section class="section-padding bg-background border-t border-white/5">
      <div class="container-custom">

        <!-- Intro -->
        <div class="max-w-3xl mb-12">
          <h2 class="reveal font-primary text-[3.125rem] font-black leading-tight mb-1">Der Moment, in dem alles zusammenkommt.</h2>
          <p class="reveal reveal-delay-100 font-secondary text-2xl text-[#927350] mb-8">Aus Komplexität wird Gewissheit, die man sofort spürt.</p>
          <p class="reveal reveal-delay-200 font-body text-base text-text/80 leading-relaxed">
            Viele Unternehmen haben genug Daten – aber zu wenig Gewissheit. In dieser Phase entsteht genau das: ein klares Bild, ein ruhiger Fokus und das sichere Gefühl, dass die nächsten Schritte nicht „irgendwie sinnvoll", sondern richtig sind. Nicht laut. Nicht kompliziert. Sondern sauber geführt.
          </p>
        </div>

        <!-- 3 Spalten -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">

          <div class="reveal reveal-delay-100">
            <h3 class="font-primary text-2xl font-black text-text mb-1">Der klare Blick</h3>
            <p class="font-secondary text-base text-[#927350] mb-4">Wenn Wirkung sichtbar wird.</p>
            <p class="font-body text-base text-text/80 leading-relaxed">
              Wir bringen alles, was heute verstreut ist, in ein Bild, das trägt. Plötzlich wird sichtbar, was wirklich wirkt – und was einfach nur beschäftigt. Diese Gewissheit fühlt sich an wie: endlich wieder Boden unter den Füßen.
            </p>
          </div>

          <div class="reveal reveal-delay-200">
            <h3 class="font-primary text-2xl font-black text-text mb-1">Das, was zählt</h3>
            <p class="font-secondary text-base text-[#927350] mb-4">Fokus, der sich gut anfühlt.</p>
            <p class="font-body text-base text-text/80 leading-relaxed">
              Aus der Gewissheit entsteht Auswahl – nicht als Verzicht, sondern als Stärke. Sie sehen, worauf es jetzt ankommt, und was warten darf. Dadurch wird Führung leicht: weniger Stimmen im Kopf, mehr Richtung.
            </p>
          </div>

          <div class="reveal reveal-delay-300">
            <h3 class="font-primary text-2xl font-black text-text mb-1">Der nächste Schritt</h3>
            <p class="font-secondary text-base text-[#927350] mb-4">Richtung, die greift.</p>
            <p class="font-body text-base text-text/80 leading-relaxed">
              Zum Schluss wird aus Fokus Bewegung: die nächsten Schritte so formuliert, dass sie im Alltag greifen. Nicht als „Plan", sondern als klare Folge, die Team und Budget mitnimmt. Man merkt: Das ist nicht Theorie – das ist Start.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- Sektion 3: Gewissheit, die bleibt -->
    <section class="section-padding bg-background border-t border-white/5">
      <div class="container-custom">
        <div class="max-w-3xl">
          <h2 class="reveal font-primary text-[3.125rem] font-black leading-tight mb-1">Gewissheit, die bleibt.</h2>
          <p class="reveal reveal-delay-100 font-secondary text-2xl text-[#927350] mb-8">Das Ergebnis.</p>
          <p class="reveal reveal-delay-200 font-body text-base text-text/80 leading-relaxed">
            Nach dem Audit haben Sie nicht „mehr Informationen", sondern ein klares Bild, das trägt. Sie sehen, wo Wirkung entsteht – und was sie verstärkt. Dadurch wird Auswahl leicht: Prioritäten fühlen sich eindeutig an. Sie investieren nicht breiter, sondern bewusster. Und Sie führen ruhiger, weil Richtung aus einem sauberen Bild entsteht – nicht aus Annahmen. Am Ende bleibt ein strategischer Vermögenswert: eine nachvollziehbare Linie, die Team, Budget und Umsetzung zusammenbringt – und sich auch dann bewährt, wenn sich Märkte bewegen.
          </p>
        </div>
      </div>
    </section>

    <!-- Sektion 4: Für wen ist der Performance Audit? (mittig) -->
    <section class="section-padding-lg bg-background border-t border-white/5">
      <div class="container-custom">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="reveal font-primary text-[3.125rem] font-black leading-tight mb-1">Für wen ist der Performance Audit?</h2>
          <p class="reveal reveal-delay-100 font-secondary text-2xl text-[#927350] mb-8">Für Unternehmen mit Anspruch an Orientierung.</p>
          <div class="reveal reveal-delay-200 font-body text-base text-text/80 leading-relaxed space-y-4 text-left">
            <p>Der Performance Audit passt zu Unternehmen, die Wachstum nicht nur „laufen lassen", sondern bewusst führen wollen. Die spüren, dass im System mehr steckt – und bereit sind, dafür genauer hinzusehen, statt nur mehr zu tun.</p>
            <p>Er passt besonders dann, wenn KI für Sie selbstverständlich ist – leise im Hintergrund, aber wirksam.</p>
            <p>Wenn Sie sich nach Orientierung sehnen, die Entscheidungen leichter macht, ist das hier der richtige Einstieg.</p>
          </div>
        </div>
      </div>
    </section>

  </HeroZone>

  <KontaktSection
    formName="kontakt-performance-audit"
    headline="Audit anfragen."
    subline="Kurzer Abgleich. Klarer Start."
    text="Sie schildern Ziel und Ausgangslage. Wenn Anspruch, Rahmen und Zusammenarbeit passen, starten wir mit dem Performance Audit – als saubere Grundlage für alles Weitere. Vertraulich. Bewusst begrenzt."
  />

</BaseLayout>
