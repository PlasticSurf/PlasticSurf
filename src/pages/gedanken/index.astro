---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { generateBreadcrumbSchema } from '../../lib/seo';

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: 'https://www.plasticsurf.de/' },
  { name: 'Gedanken', url: 'https://www.plasticsurf.de/gedanken' },
]);

// Get all blog posts
const allPosts = await getCollection('blog', ({ data }) => {
  return !data.draft;
});

// Sort by date
const sortedPosts = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const latestPost = sortedPosts[0];
const remainingPosts = sortedPosts.slice(1);

// Format date for display
function formatDate(dateString: string): string {
  return new Date(dateString).toLocaleDateString('de-DE', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout title="Gedanken - Blog - PlasticSurf">
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <!-- Hero Section: Neuester Beitrag -->
  {latestPost && (
    <section class="relative min-h-[85vh] flex items-end md:items-center overflow-hidden pt-20">
      <!-- Hintergrundbild -->
      <div class="absolute inset-0 z-0">
        <img
          src={latestPost.data.featuredImage}
          alt={latestPost.data.featuredImageAlt || latestPost.data.title}
          class="w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-r from-black/40 via-black/10 to-transparent z-10"></div>
      </div>

      <!-- Panel links -->
      <div class="container-custom w-full relative z-20 flex py-12 md:py-0">
        <a
          href={`/gedanken/${latestPost.slug}`}
          class="block w-full md:w-2/3 lg:w-1/2 bg-black/75 backdrop-blur-sm p-8 md:p-10 group rounded-lg hover:bg-black/90 hover:opacity-100 transition-colors duration-200"
        >
          <!-- H1 + Intro -->
          <h1 class="font-primary text-3xl md:text-4xl font-black text-white mb-1 leading-tight">
            Gedanken
          </h1>
          <p class="font-body text-text/60 text-sm mb-6">
            Insights, Tipps & Perspektiven aus der digitalen Welt
          </p>
          <hr class="border-white/10 mb-8" />

          <!-- Post-Titel -->
          <h2 class="font-primary text-xl md:text-2xl font-bold text-white mb-3 leading-tight group-hover:text-primary transition-colors">
            {latestPost.data.title}
          </h2>

          <!-- Teaser -->
          <p class="font-body text-text/70 text-sm leading-relaxed line-clamp-3 mb-8">
            {latestPost.data.excerpt}
          </p>

          <!-- Meta -->
          <div class="flex items-center justify-between text-xs text-text/50 mb-6">
            <span>{formatDate(latestPost.data.date)}</span>
            <span>{latestPost.data.category}</span>
          </div>

          <!-- CTA Button -->
          <span class="btn-primary inline-flex items-center gap-2">
            Zum Artikel
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </span>
        </a>
      </div>
    </section>
  )}

  <!-- Blog Posts Grid -->
  <section class="section-padding bg-background">
    <div class="container-custom">
      {remainingPosts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {remainingPosts.map((post) => (
            <article class="group">
              <a href={`/gedanken/${post.slug}`} class="block">
                <div class="aspect-video rounded-lg overflow-hidden bg-white/5 border border-white/10 mb-4">
                  <img
                    src={post.data.featuredImage}
                    alt={post.data.featuredImageAlt || post.data.title}
                    loading="lazy"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                </div>
                <span class="inline-block text-xs font-medium text-text/60 mb-2">
                  {post.data.category}
                </span>
                <h2 class="font-heading text-xl mb-2 group-hover:text-primary transition-colors">
                  {post.data.title}
                </h2>
                <p class="font-body text-text/60 text-sm line-clamp-2 mb-3">
                  {post.data.excerpt}
                </p>
                <div class="flex items-center justify-between text-xs text-text/40">
                  <span>{formatDate(post.data.date)}</span>
                  <span>{post.data.readingTime} Min. Lesezeit</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="font-body text-text/60">
            Bald erscheinen die ersten Blog-Beiträge.
          </p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>