---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { generateBlogPostingSchema, generateBreadcrumbSchema } from '../../lib/seo';
import TableOfContents from '../../components/blog/TableOfContents.astro';
import SeriesNav from '../../components/blog/SeriesNav.astro';
import CTA from '../../components/blog/CTA.astro';
import AuthorBio from '../../components/blog/AuthorBio.astro';
import RelatedPosts from '../../components/blog/RelatedPosts.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Alle Posts laden (für SeriesNav + Related Posts Scoring)
const allBlogPosts = await getCollection('blog');

// Serie laden (Sidebar-Navigation)
const seriesPosts = post.data.series
  ? allBlogPosts
      .filter(p => p.data.series === post.data.series && !p.data.draft)
      .sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0))
      .map(p => ({
        title: p.data.title,
        href: `/gedanken/${p.slug}`,
        part: p.data.seriesPart ?? 0,
        isCurrent: p.slug === post.slug,
      }))
  : [];

// Related Posts: Scoring-Algorithmus
// Ausschluss: gleicher Post, Drafts, gleiche Serie (erscheint bereits in SeriesNav)
// Scoring: Kategorie (+3), Tag-Überschneidung (+2/Tag), Keyword-Überschneidung (+1/Keyword), focusKeyword-Match (+2)
function scoreRelatedPost(candidate: typeof allBlogPosts[0]): number {
  if (candidate.slug === post.slug) return -1;
  if (candidate.data.draft) return -1;
  if (post.data.series && candidate.data.series === post.data.series) return -1;

  let score = 0;

  if (candidate.data.category === post.data.category) score += 3;

  const currentTags = ((post.data.tags ?? []) as string[]).map(t => t.toLowerCase());
  const candidateTags = ((candidate.data.tags ?? []) as string[]).map(t => t.toLowerCase());
  score += currentTags.filter(t => candidateTags.includes(t)).length * 2;

  const currentKws = ((post.data.keywords ?? []) as string[]).map(k => k.toLowerCase());
  const candidateKws = ((candidate.data.keywords ?? []) as string[]).map(k => k.toLowerCase());
  score += currentKws.filter(k => candidateKws.includes(k)).length * 1;

  if (post.data.focusKeyword && candidate.data.focusKeyword) {
    if ((post.data.focusKeyword as string).toLowerCase() === (candidate.data.focusKeyword as string).toLowerCase()) score += 2;
  }

  return score;
}

const relatedPosts = allBlogPosts
  .map(p => ({ p, score: scoreRelatedPost(p) }))
  .filter(({ score }) => score >= 0)
  .sort((a, b) =>
    b.score - a.score ||
    new Date(b.p.data.date).getTime() - new Date(a.p.data.date).getTime()
  )
  .slice(0, 3)
  .map(({ p }) => ({
    title: p.data.title,
    excerpt: (typeof p.data.excerpt === 'string' ? p.data.excerpt : '').split('\n\n')[0],
    href: `/gedanken/${p.slug}`,
    category: p.data.category ?? '',
    image: p.data.featuredImage ?? '',
    imageAlt: p.data.featuredImageAlt ?? p.data.title,
  }));

const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: 'https://www.plasticsurf.de/' },
  { name: 'Gedanken', url: 'https://www.plasticsurf.de/gedanken' },
  { name: post.data.title, url: `https://www.plasticsurf.de/gedanken/${post.slug}` },
]);

const blogPostingSchema = generateBlogPostingSchema({
  headline: post.data.metaTitle || post.data.title,
  description: post.data.metaDescription || post.data.excerpt,
  datePublished: post.data.date,
  dateModified: post.data.updated,
  author: {
    '@type': 'Person',
    name: post.data.author,
  },
  image: post.data.featuredImage,
  url: `https://www.plasticsurf.de/gedanken/${post.slug}`,
});

function formatDate(dateString: string): string {
  return new Date(dateString).toLocaleDateString('de-DE', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}
---

<BaseLayout
  title={`${post.data.metaTitle || post.data.title} - PlasticSurf`}
  description={post.data.metaDescription || post.data.excerpt}
  image={post.data.featuredImage}
  ogType="article"
>
  <script type="application/ld+json" set:html={breadcrumbSchema} />
  <script type="application/ld+json" set:html={blogPostingSchema} />

  <article class="blog-article">

    <!-- ================================================ -->
    <!-- Styles: Artikel-spezifische CSS-Deklarationen    -->
    <!-- ================================================ -->
    <style>
      .blog-article {
        background-color: #f9fafb;
      }

      .blog-article h1 {
        font-family: 'Montserrat Alternates', sans-serif;
        font-weight: 900;
      }

      .blog-article .blog-content-body {
        background-color: #f9fafb;
      }

      .blog-article .blog-content-body h2 {
        color: #111827;
      }

      .blog-article .blog-content-body h3 {
        color: #111827;
      }

      .blog-article .blog-content-body p {
        color: #1f2937;
      }

      .blog-article .blog-content-body li {
        color: #1f2937;
      }

      .blog-article .blog-content-body strong {
        color: #111827;
      }

      .blog-article .blog-content-body a {
        color: #2563eb;
      }

      .blog-article .blog-content-body blockquote {
        background-color: #f3f4f6;
        color: #374151;
      }
    </style>

    <!-- ================================================ -->
    <!-- Sektion 1: Hero – H1-Überschrift mit Hintergrundbild -->
    <!-- ================================================ -->
    <section class="relative min-h-[75vh] flex items-center justify-center overflow-hidden">
      <!-- Hintergrundbild -->
      {post.data.featuredImage && (
        <div class="absolute inset-0 z-0">
          <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/50 to-background z-10"></div>
          <img
            src={post.data.featuredImage}
            alt={post.data.featuredImageAlt || post.data.title}
            class="w-full h-full object-cover"
            width="1200"
            height="630"
            loading="eager"
          />
        </div>
      )}

      <!-- Hero Content -->
      <div class="container-custom relative z-20 text-center">
        <!-- H1 Überschrift -->
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-primary font-extrabold tracking-tight text-white mb-6 max-w-4xl mx-auto">
          {post.data.title}
        </h1>
      </div>
    </section>

    <!-- ================================================ -->
    <!-- Sektion 2: Einleitung (Excerpt / Lead-Text)     -->
    <!-- ================================================ -->
    <section class="section-padding pb-0">
      <div class="container-custom max-w-7xl">
        {post.data.lead ? (
          post.data.lead.split('\n\n').map((para) => (
            <p class="text-lg font-body mb-6 text-gray-800" style="line-height: 1.7;" set:html={para.trim()} />
          ))
        ) : post.data.excerpt && (
          post.data.excerpt.split('\n\n').map((para) => (
            <p class="text-lg font-body mb-6 text-gray-800" style="line-height: 1.7;">
              {para.trim()}
            </p>
          ))
        )}
      </div>
    </section>

    <!-- ================================================ -->
    <!-- Sektion 3: Meta-Informationen                   -->
    <!-- ================================================ -->
    <section class="section-padding">
      <div class="container-custom max-w-7xl">
        <div class="flex flex-wrap items-center gap-6 text-xs text-gray-500 pb-8 border-b border-gray-200">
          <!-- Kategorie -->
          {post.data.category && (
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
              </svg>
              <span>{post.data.category}</span>
            </div>
          )}

          <!-- Autor -->
          {post.data.author && (
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              <span>{post.data.author}</span>
            </div>
          )}

          <!-- Datum -->
          {post.data.date && (
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span>{formatDate(post.data.date)}</span>
            </div>
          )}

          <!-- Lesezeit -->
          {post.data.readingTime && (
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>{typeof post.data.readingTime === 'number' ? `${post.data.readingTime} Min.` : post.data.readingTime} Lesezeit</span>
            </div>
          )}

          <!-- Aktualisiert -->
          {post.data.updated && (
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
              <span>Aktualisiert: {formatDate(post.data.updated)}</span>
            </div>
          )}
        </div>
      </div>
    </section>

    <!-- ================================================ -->
    <!-- Sektion 4: Zwei-Spalten-Layout                  -->
    <!--   Links:  Blog-Inhalt (endet mit FAQ)           -->
    <!--   Rechts: ToC Sidebar + optionale Seriennavigation -->
    <!-- Die Sidebar endet natürlich mit dem letzten     -->
    <!-- Inhaltselement (FAQ). CTA/AuthorBio/RelatedPosts -->
    <!-- folgen danach in voller Seitenbreite.           -->
    <!-- ================================================ -->
    <section class="section-padding pt-0">
      <div class="container-custom max-w-7xl">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 xl:gap-12 items-start">

          <!-- Blog-Inhalt (MDX endet mit FAQ) -->
          <div class="lg:col-span-8 xl:col-span-8 min-w-0">
            <div class="prose max-w-3xl blog-content-body text-base">
              <Content />
            </div>
          </div>

          <!-- ToC Sidebar + optionale Seriennavigation -->
          <aside class="lg:col-span-4 xl:col-span-4 min-w-0 lg:sticky lg:top-24 self-start">
            <TableOfContents title="Auf einen Blick" />
            {seriesPosts.length > 1 && (
              <SeriesNav posts={seriesPosts} />
            )}
          </aside>

        </div>
      </div>
    </section>

    <!-- ================================================ -->
    <!-- Sektion 5: Volle Breite – CTA, AuthorBio,       -->
    <!-- RelatedPosts (außerhalb des Grids, nach FAQ)    -->
    <!-- Sidebar läuft hier nicht mehr mit.              -->
    <!-- ================================================ -->
    <div class="blog-post-footer">

      <!-- CTA -->
      <section class="section-padding pt-0">
        <div class="container-custom max-w-7xl">
          <CTA
            title="Bereit für den nächsten Schritt?"
            description="Lassen Sie uns gemeinsam Ihr Projekt starten."
            buttonText="Jetzt Gespräch vereinbaren"
            href="/kontakt"
            variant="primary"
          />
        </div>
      </section>

      <!-- AuthorBio -->
      {post.data.authorBio && (
        <section class="section-padding pt-0">
          <div class="container-custom max-w-7xl">
            <AuthorBio
              name={post.data.author}
              bio={post.data.authorBio}
              avatar={post.data.authorAvatar}
              social={post.data.authorSocial}
            />
          </div>
        </section>
      )}

      <!-- RelatedPosts (auto-scored: Kategorie + Tags + Keywords) -->
      {relatedPosts.length > 0 && (
        <section class="section-padding pt-0">
          <div class="container-custom max-w-7xl">
            <RelatedPosts
              title="Das könnte dich auch interessieren"
              posts={relatedPosts}
            />
          </div>
        </section>
      )}

    </div>

  </article>
</BaseLayout>

<!-- ================================================ -->
<!-- Styles: Blog-Content Typografie- und Farb-Overrides -->
<!-- ================================================ -->
<style>
  /* Override Tailwind prose styles für dunkle Textfarben */
  .blog-content-body {
    color: #1f2937;
  }

  /* Alle Überschriften auf font-primary setzen */
  .blog-content-body h1,
  .blog-content-body h2,
  .blog-content-body h3,
  .blog-content-body h4,
  .blog-content-body h5,
  .blog-content-body h6 {
    @apply font-primary;
    color: #111827;
  }

  /* font-weight und tracking — font-size und line-height kommen aus global.css */
  .blog-content-body h2 {
    @apply font-bold tracking-tight;
    margin-top: 60px;
    margin-bottom: 30px;
  }

  .blog-content-body h3 {
    @apply font-semibold tracking-tight;
    margin-top: 60px;
    margin-bottom: 30px;
  }

  .blog-content-body h4,
  .blog-content-body h5,
  .blog-content-body h6 {
    @apply font-semibold mt-6 mb-3;
  }

  .blog-content-body p {
    font-size: 1.25rem; /* 20px */
    line-height: 1.7;
    margin-bottom: 1.5rem;
    color: #1f2937;
  }

  .blog-content-body ul,
  .blog-content-body ol {
    font-size: 1.25rem; /* 20px */
    line-height: 1.7;
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
    color: #1f2937;
  }

  .blog-content-body ul li,
  .blog-content-body ol li {
    @apply mb-2;
    color: #1f2937;
  }

  .blog-content-body blockquote {
    @apply border-l-4 border-primary pl-6 py-4 my-8 italic rounded-r-lg;
    background-color: #f3f4f6;
    color: #374151;
  }

  .blog-content-body a {
    color: #2563eb;
    text-decoration: underline;
    text-decoration-color: rgba(37, 99, 235, 0.3);
    transition: all 0.2s;
  }

  .blog-content-body a:hover {
    text-decoration-color: #2563eb;
  }

  .blog-content-body strong {
    @apply font-semibold;
    color: #111827;
  }

  .blog-content-body img {
    @apply rounded-lg my-8 w-full;
  }

  .blog-content-body hr {
    @apply my-12;
    border-color: #e5e7eb;
  }

  .blog-content-body code {
    @apply px-2 py-1 rounded text-sm;
    background-color: #f3f4f6;
    color: #1f2937;
  }

  .blog-content-body pre {
    @apply p-4 rounded-lg my-6 overflow-x-auto;
    background-color: #1f2937;
    color: #f9fafb;
  }

  .blog-content-body pre code {
    background-color: transparent;
    color: inherit;
    padding: 0;
  }

  .blog-content-body table {
    @apply w-full my-6;
  }

  .blog-content-body th {
    @apply font-semibold text-left py-2 px-4;
    background-color: #f3f4f6;
    color: #111827;
  }

  .blog-content-body td {
    @apply py-2 px-4 border-t;
    border-color: #e5e7eb;
    color: #1f2937;
  }

  .blog-content-body div {
    color: #1f2937;
  }

  .blog-content-body span {
    color: #1f2937;
  }

  /* Lead-Text (Intro) Styling */
  .blog-content-body .lead {
    @apply text-base font-secondary leading-relaxed italic mb-8;
    color: #1f2937;
  }
</style>
