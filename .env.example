# Google Analytics ID (optional)
GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Cloudflare Turnstile — https://dash.cloudflare.com → Application security → Turnstile
PUBLIC_TURNSTILE_SITE_KEY=0x...   # Site Key (öffentlich, im Browser sichtbar)
TURNSTILE_SECRET_KEY=0x...        # Secret Key (nur Server)

# SMTP via Brevo — https://app.brevo.com → Settings → SMTP & API
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=xxxx@smtp-brevo.com     # Brevo SMTP Login
SMTP_PASS=xsmtpsib-...            # Brevo SMTP API Key
SMTP_FROM=ihre@domain.de          # Absender (verifizierte Brevo-Sender-Adresse)
SMTP_TO=ihre@domain.de            # Empfänger
